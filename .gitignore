# See https://help.github.com/articles/ignoring-files/

# =========================
# Dependencies
# =========================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================
# Build outputs
# =========================
/.next/
/out/
/build

# =========================
# Testing
# =========================
/coverage

# =========================
# Environment variables
# Never commit secrets
# =========================
.env
.env.*
!.env.example

# =========================
# Vercel
# =========================
.vercel

# =========================
# TypeScript
# =========================
*.tsbuildinfo

# next-env.d.ts is auto-generated by Next.js
# Uncomment if you don't want to track it
# next-env.d.ts

# =========================
# Logs
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =========================
# IDE / Editor
# =========================
.vscode/
.idea/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Cache files
# =========================
.eslintcache

# =========================
# Docker
# =========================
docker-compose.override.yml

# =========================
# Security
# =========================
*.pem
*.key